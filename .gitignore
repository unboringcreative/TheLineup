# -----------------------------------------------------------------------------
# Case workflow local/runtime artifacts
# -----------------------------------------------------------------------------
case_workflow/.venv/
case_workflow/**/__pycache__/
case_workflow/**/*.pyc

# Generated render outputs and local model snapshots
case_workflow/outputs/
case_workflow/models/

# Local scratch/reference artifacts (do not version by default)
case_workflow/artifacts/reference_outputs/
case_workflow/artifacts/scratch/

# Optional generated Unity import drop (keep folder + meta files)
Assets/GeneratedCases/to_import/**
!Assets/GeneratedCases/to_import/
!Assets/GeneratedCases/to_import.meta
!Assets/GeneratedCases/to_import/**/*.meta

